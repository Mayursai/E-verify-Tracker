# Environment Variables

# DATABASE
# Supabase: use the "Session pooler" connection string from the Supabase
# dashboard -> Connect. It looks like:
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# (The direct db.<ref>.supabase.co host is IPv6-only; prefer the pooler.)
# Local dev: any Postgres works, e.g. postgresql://user:password@localhost:5432/everify
DATABASE_URL=postgresql://user:password@host:5432/database

# TLS for the database connection. Auto-detected (on in production and for
# Supabase/Render/Neon hosts, off for local). Set true/false to override.
# DATABASE_SSL=true

# Max pool connections (default 5 - keep low on Supabase's free pooler).
# PG_POOL_MAX=5

# SERVER
NODE_ENV=production
PORT=3000
SESSION_SECRET=your-secret-key-change-this
